---
// Homepage — services preview. Answers the visitor's first question:
// "do they do my kind of job?" Pulls labels straight from the taxonomy
// (single source of truth) so it never drifts from the Serviços page.
import { services, type Lang } from '../data/taxonomies';

const lang: Lang = 'pt';

const families: { key: 'construction' | 'engineering'; label: string }[] = [
  { key: 'construction', label: 'Reabilitação e Construção' },
  { key: 'engineering', label: 'Engenharia' },
];

const grouped = families.map((f) => ({
  label: f.label,
  items: Object.entries(services)
    .filter(([, v]) => v.family === f.key)
    .map(([key, v]) => ({ key, label: v[lang] ?? v.en })),
}));
---

<section class="bg-paper">
  <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
    <div class="flex flex-wrap items-end justify-between gap-x-6 gap-y-8">
      <div>
        <p class="mb-6 font-mono text-xs uppercase tracking-[0.25em] text-muted">
          Serviços
        </p>
        <h2 class="max-w-2xl font-display text-3xl font-bold leading-tight text-charcoal">
          Construção e engenharia.
        </h2>
      </div>
      <a
        href="/servicos"
        class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-accent transition-colors hover:text-accent-hover"
      >
        Ver todos os serviços
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>

    <div class="mt-14 grid gap-x-16 gap-y-12 md:mt-20 md:grid-cols-2">
      {
        grouped.map((group) => (
          <div>
            <p class="mb-2 font-mono text-xs uppercase tracking-[0.25em] text-accent">
              {group.label}
            </p>
            <ul>
              {group.items.map((s) => (
                <li class="border-t border-line py-4">
                  <span class="font-display text-lg font-bold leading-snug text-charcoal">
                    {s.label}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
