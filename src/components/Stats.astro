---
// Placeholder figures — replace with REMAIA's real numbers.
const stats = [
  { value: '2018', label: 'Fundada' },
  { value: '6', label: 'Áreas de atuação' },
  { value: '40+', label: 'Obras concluídas' },
  { value: '25.000 m²', label: 'Intervencionados' },
];
---

<section class="bg-charcoal text-paper">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-10 md:py-20">
    <div class="grid grid-cols-2 gap-y-10 md:grid-cols-4 md:gap-y-0">
      {
        stats.map((s) => (
          <div class="border-l border-line-dark pl-5">
            <div class="font-display text-[2rem] font-bold leading-none md:text-[2.5rem]">
              {s.value}
            </div>
            <div class="mt-3 font-mono text-xs uppercase tracking-widest text-paper/50">
              {s.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
