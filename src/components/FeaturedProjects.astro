---
import { getCollection } from 'astro:content';
import { categoryLabel, type Lang } from '../data/taxonomies';

interface Props {
  lang?: Lang;
}
const { lang = 'pt' } = Astro.props;

const featured = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<section class="bg-paper">
  <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
    <!-- Section head -->
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="mb-5 font-mono text-xs uppercase tracking-[0.25em] text-muted">
          Seleção
        </p>
        <h2 class="font-display text-3xl font-bold leading-tight text-charcoal">
          Projetos recentes.
        </h2>
      </div>
      <a
        href="/projetos"
        class="hidden shrink-0 font-mono text-xs uppercase tracking-widest text-accent underline-offset-4 transition-colors hover:text-accent-hover hover:underline md:inline-block"
      >
        Ver todos &rarr;
      </a>
    </div>

    <!-- Grid -->
    <div class="mt-14 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((p) => (
          <a href="/projetos" class="group block">
            <div class="relative aspect-[4/3] overflow-hidden bg-charcoal">
              <img
                src={p.data.cover}
                alt={p.data.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <p class="mt-4 font-mono text-xs uppercase tracking-widest text-accent">
              {categoryLabel(p.data.category, lang)}
            </p>
            <h3 class="mt-2 font-display text-xl font-bold leading-snug text-charcoal">
              {p.data.title}
            </h3>
            <p class="mt-2 font-mono text-xs uppercase tracking-wide text-muted">
              {p.data.year} &middot; {p.data.location}
              {p.data.area ? ` · ${p.data.area}` : ''}
            </p>
          </a>
        ))
      }
    </div>

    <!-- Mobile "see all" -->
    <div class="mt-12 md:hidden">
      <a
        href="/projetos"
        class="font-mono text-xs uppercase tracking-widest text-accent underline underline-offset-4"
      >
        Ver todos os projetos &rarr;
      </a>
    </div>
  </div>
</section>
