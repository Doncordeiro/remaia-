---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import { services, type Lang } from '../data/taxonomies';

const lang: Lang = 'pt';

// PT descriptions (page copy — first pass, review wording)
const descriptions: Record<string, string> = {
  rehab_restoration: 'Estruturas, fachadas e coberturas.',
  space_adaptation: 'Adaptação de espaços para comércio e habitação.',
  maintenance: 'Manutenção industrial e de edifícios.',
  exteriors: 'Paisagismo, pavimentação e jardinagem.',
  carpentry_metalwork: 'Trabalhos de madeira e metalomecânica.',
  turnkey: 'Construção nova, do projeto à entrega.',
  infrastructure: 'Redes, acessos e obras de infraestrutura.',
  pathology_diagnosis: 'Identificação de patologias e soluções de reabilitação.',
  construction_management: 'Coordenação e gestão de empreitadas.',
  engineering_projects: 'Conceção e desenvolvimento de projeto.',
  consulting: 'Apoio técnico e consultoria especializada.',
  inspection: 'Fiscalização e controlo de qualidade em obra.',
};

const familyLabels: { key: 'construction' | 'engineering'; label: string }[] = [
  { key: 'construction', label: 'Reabilitação e Construção' },
  { key: 'engineering', label: 'Engenharia' },
];

// Flatten with continuous 01–12 numbering, then group by family
const flat = Object.entries(services).map(([key, v], i) => ({
  key,
  n: i + 1,
  label: v[lang] ?? v.en,
  family: v.family,
  desc: descriptions[key] ?? '',
}));

const grouped = familyLabels.map((f) => ({
  label: f.label,
  items: flat.filter((s) => s.family === f.key),
}));
---

<Base
  title="Serviços — REMAIA"
  description="Reabilitação, construção e engenharia. Os serviços da REMAIA, da inspeção à entrega da obra."
>
  <Header variant="solid" />

  <main class="bg-paper">
    <!-- Intro -->
    <section>
      <div class="mx-auto max-w-7xl px-6 pb-16 pt-24 md:px-10 md:pb-20 md:pt-32">
        <p class="mb-6 font-mono text-xs uppercase tracking-[0.25em] text-muted">Serviços</p>
        <h1 class="max-w-3xl font-display text-4xl font-bold leading-tight text-charcoal">
          O que fazemos.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-charcoal/80">
          Duas frentes — construção e engenharia — tratadas pela mesma equipa, da primeira
          inspeção à entrega da obra.
        </p>
      </div>
    </section>

    <!-- Service families -->
    {
      grouped.map((group) => (
        <section>
          <div class="mx-auto max-w-7xl px-6 pb-8 md:px-10 md:pb-12">
            <div class="border-t border-line pt-10">
              <p class="mb-10 font-mono text-xs uppercase tracking-[0.25em] text-accent">
                {group.label}
              </p>
              <div class="grid gap-x-12 gap-y-10 md:grid-cols-2">
                {group.items.map((s) => (
                  <div class="flex gap-5">
                    <span class="font-mono text-xs text-muted">
                      {String(s.n).padStart(2, '0')}
                    </span>
                    <div>
                      <h2 class="font-display text-xl font-bold leading-snug text-charcoal">
                        {s.label}
                      </h2>
                      <p class="mt-2 max-w-md text-base leading-relaxed text-muted">{s.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))
    }

    <!-- CTA -->
    <section>
      <div class="mx-auto max-w-7xl px-6 pb-24 pt-16 md:px-10 md:pb-32 md:pt-24">
        <div class="border-t border-line pt-12">
          <h2 class="max-w-2xl font-display text-2xl font-bold leading-snug text-charcoal md:text-3xl">
            Tem uma obra em mãos?
          </h2>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-muted">
            Conte-nos o que precisa. Respondemos com um diagnóstico, não com um orçamento automático.
          </p>
          <a
            href="/contacto"
            class="group mt-8 inline-flex items-center gap-2 bg-accent px-6 py-3 font-mono text-xs uppercase tracking-widest text-paper transition-colors hover:bg-accent-hover"
          >
            Falar connosco
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>
