---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Intro from '../components/Intro.astro';
import Stats from '../components/Stats.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
---

<Base>
  <Header />

  <main>
    <!-- Hero -->
    <section class="relative flex min-h-screen flex-col justify-end overflow-hidden">
      <img
        src="/hero.jpg"
        alt="Equipa REMAIA a rever projetos de execução sobre a planta de uma obra"
        class="absolute inset-0 h-full w-full object-cover"
        style="object-position: center;"
        fetchpriority="high"
      />

      <div
        class="absolute inset-0"
        style="background: linear-gradient(to top, rgba(20,20,20,0.90) 0%, rgba(20,20,20,0.15) 45%, rgba(20,20,20,0.55) 100%);"
      >
      </div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to right, rgba(20,20,20,0.65) 0%, rgba(20,20,20,0) 58%);"
      >
      </div>

      <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pb-20 md:px-10 md:pb-28">
        <p class="mb-5 font-mono text-xs uppercase tracking-[0.25em] text-paper/70">
          Reabilitação &middot; Construção &middot; Engenharia
        </p>

        <h1 class="max-w-4xl font-display text-4xl font-bold text-paper md:text-5xl">
          Construímos para durar.
        </h1>

        <p class="mt-6 max-w-xl text-lg text-paper/80">
          Reabilitação, construção nova e engenharia, executadas com rigor técnico. Sediados na Maia.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href="/projetos"
            class="group inline-flex items-center gap-2 bg-accent px-6 py-3 font-mono text-xs uppercase tracking-widest text-paper transition-colors hover:bg-accent-hover"
          >
            Ver projetos
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
          <a
            href="/contacto"
            class="inline-flex items-center px-2 py-3 font-mono text-xs uppercase tracking-widest text-paper/80 underline-offset-4 transition-colors hover:text-paper hover:underline"
          >
            Falar connosco
          </a>
        </div>
      </div>

      <div
        class="absolute bottom-6 right-6 hidden font-mono text-[10px] uppercase tracking-widest text-paper/50 md:right-10 md:block"
      >
        41.23&deg;N &middot; 8.62&deg;W
      </div>
    </section>

    <Intro />
    <Stats />
    <FeaturedProjects />
  </main>
</Base>
