---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';

const mapUrl = 'https://goo.gl/maps/bGRgnxh8YVaaubYPA';
// Non-interactive embedded map, centered on the address (no API key needed)
const mapEmbed =
  'https://maps.google.com/maps?q=Rua%20do%20Xisto%20712%2C%204470-389%20Maia&z=16&hl=pt&output=embed';
---

<Base
  title="Contacto — REMAIA"
  description="Fale com a REMAIA. Rua do Xisto, 712, Maia. geral@remaia.pt · +351 960 006 063."
>
  <Header variant="solid" />

  <main class="bg-paper">
    <!-- Intro -->
    <section>
      <div class="mx-auto max-w-7xl px-6 pb-12 pt-24 md:px-10 md:pb-16 md:pt-28">
        <p class="mb-6 font-mono text-xs uppercase tracking-[0.25em] text-muted">Contacto</p>
        <h1 class="max-w-3xl font-display text-4xl font-bold leading-tight text-charcoal">
          Vamos falar.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-charcoal/80">
          Uma obra, uma dúvida técnica ou um pedido de orçamento — fale connosco diretamente.
          Respondemos a todos os contactos.
        </p>
      </div>
    </section>

    <!-- Contact panel -->
    <section>
      <div class="mx-auto max-w-7xl px-6 pb-24 md:px-10 md:pb-32">
        <div class="grid overflow-hidden bg-charcoal text-paper md:grid-cols-2">
          <!-- Details -->
          <div class="border-line-dark p-8 md:border-r md:p-12">
            <p class="font-mono text-xs uppercase tracking-[0.25em] text-paper/40">Escreva-nos</p>
            <a
              href="mailto:geral@remaia.pt"
              class="mt-3 inline-block font-display text-2xl font-bold leading-snug text-paper transition-colors hover:text-blue md:text-[1.75rem]"
            >
              geral@remaia.pt
            </a>

            <p class="mt-10 font-mono text-xs uppercase tracking-[0.25em] text-paper/40">Telefone</p>
            <ul class="mt-3 space-y-1.5 text-lg text-paper/90">
              <li><a href="tel:+351960006063" class="transition-colors hover:text-blue">+351 960 006 063</a></li>
              <li><a href="tel:+351229426580" class="transition-colors hover:text-blue">+351 229 426 580</a></li>
            </ul>

            <p class="mt-10 font-mono text-xs uppercase tracking-[0.25em] text-paper/40">Morada</p>
            <p class="mt-3 text-lg leading-relaxed text-paper/70">
              Rua do Xisto, 712<br />
              4470-389 Maia, Portugal
            </p>
          </div>

          <!-- Locator: real map beneath, crosshair on top -->
          <div class="relative min-h-[340px] overflow-hidden bg-charcoal">
            <!-- Map (desaturated + dark-toned, non-interactive) -->
            <iframe
              src={mapEmbed}
              title="Localização da REMAIA — Rua do Xisto, 712, Maia"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="absolute inset-0 h-full w-full border-0"
              style="filter: grayscale(1) invert(0.9) brightness(0.95) contrast(0.92); pointer-events: none;"
            ></iframe>

            <!-- Overlay: corner tick + crosshair (non-interactive) -->
            <div class="pointer-events-none absolute inset-0">
              <div class="absolute left-6 top-6 h-8 w-8 border-l-2 border-t-2 border-blue"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <svg
                  viewBox="0 0 64 64"
                  class="h-14 w-14 text-paper"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.25"
                  style="filter: drop-shadow(0 0 4px rgba(0,0,0,0.85));"
                >
                  <circle cx="32" cy="32" r="9" />
                  <line x1="32" y1="3" x2="32" y2="18" stroke-linecap="round" />
                  <line x1="32" y1="46" x2="32" y2="61" stroke-linecap="round" />
                  <line x1="3" y1="32" x2="18" y2="32" stroke-linecap="round" />
                  <line x1="46" y1="32" x2="61" y2="32" stroke-linecap="round" />
                  <circle cx="32" cy="32" r="1.75" fill="currentColor" stroke="none" />
                </svg>
              </div>
            </div>

            <!-- Bottom bar: coordinates + map link (clickable) -->
            <div
              class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-4 px-6 py-5"
              style="background: linear-gradient(to top, rgba(20,20,20,0.92) 0%, rgba(20,20,20,0) 100%);"
            >
              <span class="font-mono text-xs tracking-wide text-paper/80">41.23&deg;N &middot; 8.62&deg;W</span>
              <a
                href={mapUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-paper/80 transition-colors hover:text-paper"
              >
                Abrir no Google Maps
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
